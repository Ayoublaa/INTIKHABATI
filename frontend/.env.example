# ======================================================
#  CivicChain — Variables d'environnement frontend
#  Copiez ce fichier en .env et remplissez les valeurs
#  NE JAMAIS committer le fichier .env !
# ======================================================

# URL de l'API backend
REACT_APP_API_URL=http://localhost:3001/api

# Adresse du compte owner (mise à jour par deploy.js)
REACT_APP_OWNER_ADDRESS=

# Adresses des contrats (mises à jour automatiquement par deploy.js)
REACT_APP_CONTRACT_ADDRESS=
REACT_APP_FORWARDER_ADDRESS=
REACT_APP_MULTISIG_ADDRESS=
