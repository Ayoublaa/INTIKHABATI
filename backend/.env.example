# ======================================================
#  CivicChain — Variables d'environnement backend
#  Copiez ce fichier en .env et remplissez les valeurs
#  NE JAMAIS committer le fichier .env !
# ======================================================

# MongoDB
MONGO_URI=mongodb://localhost:27017/civicchain

# JWT Secret (choisissez une valeur longue et aléatoire)
JWT_SECRET=

# Clé privée du wallet OWNER du smart contract
# En local : utilisez le compte Hardhat #0
OWNER_PRIVATE_KEY=

# Adresse du smart contract CivicChain (mise à jour par deploy.js)
CONTRACT_ADDRESS=

# RPC Ethereum (Hardhat local ou Sepolia)
RPC_URL=http://127.0.0.1:8545

# Port du serveur
PORT=3001

# Email (nodemailer — Gmail SMTP)
EMAIL_USER=
EMAIL_PASS=
ADMIN_EMAIL=

# IPFS — Pinata (optionnel)
# Créez un compte sur https://app.pinata.cloud → API Keys → New Key → JWT
PINATA_JWT=

# EIP-2771 Meta-Transactions
FORWARDER_ADDRESS=

# MultiSig 2-of-3 (mis à jour par deploy.js)
MULTISIG_ADDRESS=
MULTISIG_OWNER_0=
MULTISIG_OWNER_1=
MULTISIG_OWNER_2=
MULTISIG_OWNER_0_PK=
MULTISIG_OWNER_1_PK=
MULTISIG_OWNER_2_PK=
